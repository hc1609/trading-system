# ============================================================
# 交易策略系统 - 环境变量配置
# 
# 使用方式:
#   1. 复制此文件: cp .env.example .env
#   2. 修改 .env 中的值
#   3. 启动: docker-compose up -d
#
# 架构说明:
#   - 本应用: 单容器 (Django + Vue前端 + Celery)
#   - 外部依赖: MySQL + Redis (需自行准备)
#   - 可选: Nginx反向代理 (推荐生产环境使用)
# ============================================================

# ------------------- Django核心配置 -------------------
# 安全密钥 (生产环境必须修改! 可使用: openssl rand -base64 50)
SECRET_KEY=your-super-secret-key-change-this-in-production

# 调试模式 (生产环境必须设为False)
DEBUG=False

# 允许访问的主机 (逗号分隔, 生产环境设置实际域名)
ALLOWED_HOSTS=localhost,127.0.0.1,*

# ------------------- 数据库配置 (外部MySQL) -------------------
# MySQL主机地址 (容器部署时填宿主机IP, 本机部署填localhost)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=trading_system
DB_USER=trading
DB_PASSWORD=your-mysql-password

# ------------------- Redis配置 (外部Redis) -------------------
# Redis主机地址 (容器部署时填宿主机IP, 本机部署填localhost)
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------- Tushare API (可选) -------------------
# 从 https://tushare.pro/ 注册获取
TUSHARE_TOKEN=your-tushare-token

# ------------------- 管理员账号配置 -------------------
# 首次启动时自动创建超级用户
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@example.com
